# Copy this file to ".env" and fill in your key.
# A key is only needed for the LLM features (translation + summarization).
# Transcription works fully without any key.

# ---- LLM provider (default: groq) -------------------------------------------
# Groq powers translation and summarization by default. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# ---- Optional overrides (sensible defaults are used if omitted) -------------
# LLM_PROVIDER=groq             # groq (default) | anthropic (backwards compat)
# GROQ_MODEL=llama-3.3-70b-versatile   # or llama-3.1-8b-instant for speed/cost
# SUMMARY_MODEL=llama-3.3-70b-versatile

# ---- Anthropic (legacy) — only used when LLM_PROVIDER=anthropic -------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6
# TRANSLATION_MODEL=             # explicit model override; must match the provider

# ---- Transcription / runtime overrides -------------------------------------
# WHISPER_MODEL=large-v3        # large-v3 | medium | small | base | tiny
# DEVICE=cuda                   # cuda | cpu  (auto-detected by default)
# COMPUTE_TYPE=float16          # float16 (GPU) | int8 (CPU)
# MAX_FILE_SIZE_MB=500
